# ============================================================================
# Global-Tasks-dos - Environment Variables (Example)
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit the actual .env file to version control.
# ============================================================================

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
BUILD_TARGET=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=global_tasks
POSTGRES_USER=globaltasks
POSTGRES_PASSWORD=changeme_in_prod

# ─── Cache (Redis) ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ─── Message Broker (RabbitMQ) ────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── API Gateway ──────────────────────────────────────────────────────────────
API_GATEWAY_PORT=8000
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Agents Service ──────────────────────────────────────────────────────────
AGENTS_SERVICE_PORT=8001
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AGENT_MODEL=gpt-4o
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.7

# ─── CRM Service ──────────────────────────────────────────────────────────────
CRM_SERVICE_PORT=8002

# ─── Workflow Engine ──────────────────────────────────────────────────────────
WORKFLOW_ENGINE_PORT=8003
WORKFLOW_MAX_EXECUTION_TIME_SEC=300
WORKFLOW_MAX_STEPS=50
WORKFLOW_CONCURRENCY=10

# ─── Realtime Service (WebSocket) ────────────────────────────────────────────
REALTIME_SERVICE_PORT=8004
SOCKET_IO_CORS_ORIGINS=http://localhost:3000,http://localhost

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/socket.io
NEXT_PUBLIC_APP_URL=http://localhost

# ─── Integrations (optional) ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
HUBSPOT_API_KEY=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@globaltasks.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
